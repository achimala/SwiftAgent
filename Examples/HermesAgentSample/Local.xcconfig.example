// Copy this file to Local.xcconfig to run the sample app on a physical device.
// Local.xcconfig is ignored by git so your Apple team ID and bundle prefix stay private.
// The sample worker extension is statically bound to com.daysail.HermesAgentSample.
// Keep this prefix unless you also update HermesAgentWorker.swift's AppExtensionPoint host.

SWIFTAGENT_SAMPLE_DEVELOPMENT_TEAM = YOURTEAMID
SWIFTAGENT_SAMPLE_BUNDLE_ID_PREFIX = com.daysail
